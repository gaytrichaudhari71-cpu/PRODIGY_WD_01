<!-- Sections -->
<section id="home">
  <div class="orb orb-gold"></div>
  <div class="section-label">Est. 2024 — Creative Studio</div>
  <h1 class="section-title">Design that <em>moves</em> people forward</h1>
  <p class="section-body">We craft digital experiences that sit at the intersection of craft, clarity, and culture. Scroll to explore, hover to discover.</p>
</section>

<section id="work">
  <div class="orb orb-rust"></div>
  <div class="section-label">Selected Projects</div>
  <h2 class="section-title">Our <em>Work</em></h2>
  <p class="section-body">A curated selection of brand identities, digital products, and spatial experiences from our archive of collaborations.</p>
</section>

<section id="process">
  <div class="orb orb-teal"></div>
  <div class="section-label">How We Think</div>
  <h2 class="section-title">The <em>Process</em></h2>
  <p class="section-body">Every project begins with deep listening. We map the territory, find the tension, then resolve it into something that feels inevitable.</p>
</section>

<section id="about">
  <div class="orb orb-gold"></div>
  <div class="section-label">Who We Are</div>
  <h2 class="section-title"><em>About</em> the Studio</h2>
  <p class="section-body">A small, deliberate team of designers, strategists, and builders united by a belief that great design changes behavior, not just perception.</p>
</section>

<section id="contact">
  <div class="orb orb-rust"></div>
  <div class="section-label">Let's Talk</div>
  <h2 class="section-title">Start a <em>Conversation</em></h2>
  <p class="section-body">Have a project in mind? We'd love to hear about it. Send us a message and we'll get back to you within one business day.</p>
</section>



</body></html>
