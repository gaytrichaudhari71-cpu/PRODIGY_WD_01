Content-Location: cid:css-678f7447-d3b1-451d-ada1-93b42a134fcc@mhtml.blink

@charset "utf-8";

:root { --nav-bg-init: transparent; --nav-bg-scroll: rgba(10, 10, 10, 0.97); --accent: #e8c97a; --accent-dim: rgba(232, 201, 122, 0.15); --text-light: #f5f0e8; --text-muted: rgba(245, 240, 232, 0.45); --transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); }

* { margin: 0px; padding: 0px; box-sizing: border-box; }

nav { position: fixed; top: 0px; left: 0px; right: 0px; z-index: 100; padding: 28px 56px; display: flex; align-items: center; justify-content: space-between; background: var(--nav-bg-init); border-bottom: 1px solid transparent; transition: background var(--transition),
                border-color var(--transition),
                padding var(--transition),
                backdrop-filter var(--transition); }

nav.scrolled { padding: 18px 56px; background: var(--nav-bg-scroll); border-color: rgba(232, 201, 122, 0.12); backdrop-filter: blur(14px); }

.nav-logo { font-family: "Playfair Display", serif; font-size: 1.45rem; font-weight: 700; color: var(--text-light); letter-spacing: 0.02em; text-decoration: none; position: relative; }

.nav-logo span { color: var(--accent); }

.nav-links { display: flex; list-style: none; gap: 0px; }

.nav-links li { position: relative; }

.nav-links a { display: block; padding: 10px 22px; font-family: "DM Mono", monospace; font-size: 0.78rem; font-weight: 300; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; transition: color var(--transition); position: relative; overflow: hidden; }

.nav-links a::after { content: ""; position: absolute; bottom: 4px; left: 22px; right: 22px; height: 1px; background: var(--accent); transform: scaleX(0); transform-origin: left center; transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1); }

.nav-links a::before { content: ""; position: absolute; inset: 0px; background: var(--accent-dim); opacity: 0; transition: opacity 0.35s; border-radius: 3px; }

.nav-links a:hover { color: var(--accent); }

.nav-links a:hover::after { transform: scaleX(1); }

.nav-links a:hover::before { opacity: 1; }

.nav-links a.active { color: var(--accent); }

.nav-links a.active::after { transform: scaleX(1); }

nav.scrolled .nav-links a { color: rgba(245, 240, 232, 0.65); }

nav.scrolled .nav-links a:hover, nav.scrolled .nav-links a.active { color: var(--accent); }

.nav-cta { font-family: "DM Mono", monospace; font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; border-radius: 2px; color: var(--accent) !important; border: 1px solid var(--accent) !important; padding: 9px 22px !important; transition: background 0.3s, color 0.3s !important; }

.nav-cta:hover { background: var(--accent) !important; color: rgb(10, 10, 10) !important; }

.nav-cta::before, .nav-cta::after { display: none !important; }

.scroll-indicator { position: fixed; top: 0px; left: 0px; height: 2px; background: linear-gradient(90deg, var(--accent), #f0a060); z-index: 200; width: 0%; transition: width 0.1s linear; }

body { background: rgb(8, 8, 8); color: var(--text-light); font-family: "DM Mono", monospace; }

section { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120px 56px 80px; position: relative; overflow: hidden; }

section:nth-child(2n+1) { background: rgb(8, 8, 8); }

section:nth-child(2n) { background: rgb(15, 15, 15); }

.section-label { font-size: 0.68rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 24px; opacity: 0.8; }

.section-title { font-family: "Playfair Display", serif; font-size: clamp(3rem, 8vw, 7rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.01em; color: var(--text-light); text-align: center; max-width: 900px; }

.section-title em { color: var(--accent); font-style: italic; }

.section-body { margin-top: 32px; max-width: 520px; text-align: center; font-size: 0.82rem; line-height: 1.9; color: var(--text-muted); }

.orb { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; opacity: 0.18; }

.orb-gold { background: rgb(232, 201, 122); width: 500px; height: 500px; top: -100px; right: -100px; }

.orb-rust { background: rgb(212, 112, 74); width: 400px; height: 400px; bottom: -80px; left: -80px; }

.orb-teal { background: rgb(90, 184, 168); width: 350px; height: 350px; top: 50%; left: 50%; transform: translate(-50%, -50%); }

.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; background: none; border: none; }

.hamburger span { display: block; width: 24px; height: 1.5px; background: var(--text-light); transition: 0.3s; transform-origin: center center; }

.hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }

.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }

.hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

@media (max-width: 768px) {
  nav { padding: 22px 28px; }
  nav.scrolled { padding: 16px 28px; }
  .hamburger { display: flex; }
  .nav-links { position: fixed; top: 0px; right: 0px; bottom: 0px; width: 280px; background: rgb(10, 10, 10); flex-direction: column; padding: 100px 40px 60px; gap: 8px; border-left: 1px solid rgba(232, 201, 122, 0.12); transform: translateX(100%); transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1); }
  .nav-links.open { transform: translateX(0px); }
  .nav-links a { font-size: 0.85rem; padding: 14px 0px; }
  .nav-links a::after { left: 0px; right: auto; width: 40px; bottom: 10px; }
  .nav-cta { margin-top: 16px; display: inline-block; }
  section { padding: 120px 28px 80px; }
  .section-title { font-size: clamp(2.2rem, 12vw, 4rem); }
}
------MultipartBoundary--DeqXW8jvlW2DC7IQL01yZuKhIGoHo5Qy2p19NhLZh3------
