.od-PermissionsPanel-head { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }

.od-PermissionsPanel-fileName { font-size: 0.875rem; color: rgb(97, 97, 97); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; height: 1.5625rem; }

[dir="ltr"] .od-PermissionsPanel-fileName { padding-right: 2.5rem; }

[dir="rtl"] .od-PermissionsPanel-fileName { padding-left: 2.5rem; }

.od-PermissionsPanel-fileName .od-PermissionsPanel-Path { padding: 0.1875rem; display: inline-block; vertical-align: middle; }

.od-PermissionsPanel-fileName .od-PermissionsPanel-Path .od-PermissionsPanel-Path-Element { display: inline; word-break: break-all; }

.od-PermissionsPanel-fileName .od-PermissionsPanel-Path .od-PermissionsPanel-Path-Element::after { display: inline-block; font-family: FabricMDL2Icons; font-style: normal; speak: none; color: rgb(97, 97, 97); padding: 0px 0.3125rem; font-size: 0.5rem; font-weight: 800; content: "ŅØ¼"; }

