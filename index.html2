@charset "utf-8";

.ms-ContextualMenu-icon { font-size: 1rem; width: 1rem; }

.ms-ContextualMenu-icon.ms-Icon--Info { margin-top: 2px; }

.ms-ContextualMenu-icon[data-icon-name="ExcelLogo"] { color: rgb(33, 115, 70); }

.ms-ContextualMenu-icon[data-icon-name="OneNoteLogo"] { color: rgb(92, 45, 145); }

.ms-ContextualMenu-icon[data-icon-name="PowerPointLogo"] { color: rgb(210, 71, 38); }

.ms-ContextualMenu-icon[data-icon-name="WordLogo"] { color: rgb(43, 87, 154); }

.ms-ContextualMenu-icon[data-icon-name="VisioLogo"] { color: rgb(56, 84, 162); }

.ms-ContextualMenu-icon.od-NeedsAttentionViewIcon { color: rgb(164, 38, 44); }

.ms-ContextualMenu-icon.ms-Icon--CustomIcon, .ms-ContextualMenu-icon.ms-Icon--custom { width: 1rem; height: 2.25rem; background-size: contain; }

.ms-ContextualMenu-link { font-size: 0.875rem; height: 2.25rem; line-height: 2.25rem; }

.ContextualMenu-uploadInput { position: absolute; inset: 0px; opacity: 0.0001; cursor: pointer; overflow: hidden; z-index: 9999999; }

.ContextualMenu-uploadInput input { position: absolute; top: 0px; font-size: 200px; height: 100px; cursor: pointer; margin: 0px; padding: 0px; }

[dir="ltr"] .ContextualMenu-uploadInput input { right: 0px; }

[dir="rtl"] .ContextualMenu-uploadInput input { left: 0px; }

.ContextualMenu-uploadInput-container { box-sizing: border-box; padding: 0px; }

.ContextualMenu-uploadInput-Text { display: block; }
