html[dir="ltr"] .od-PermissionsPanel-shareLink { float: right; }

html[dir="rtl"] .od-PermissionsPanel-shareLink { float: left; }

.od-PermissionPile-accessibleLabel { position: absolute; width: 1px; height: 1px; padding: 0px; margin: -1px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); border: 0px; }

.od-PermissionsPanel-stopSharing { color: rgb(0, 120, 212); font-size: 1rem; background: 0px 0px; border: none; padding: 0px; cursor: pointer; }

.od-PermissionsPanel-stopSharing:focus, .od-PermissionsPanel-stopSharing:hover { color: rgb(0, 90, 158); }

