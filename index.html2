@-webkit-keyframes headerSlideInFrames { 
  0% { height: 8px; opacity: 0; transform: scale(0.95); }
  100% { height: 48px; opacity: 1; transform: scale(1); }
}

@keyframes headerSlideInFrames { 
  0% { height: 8px; opacity: 0; transform: scale(0.95); }
  100% { height: 48px; opacity: 1; transform: scale(1); }
}

@-webkit-keyframes headerSlideOutFrames { 
  0% { visibility: visible; display: flex; height: 48px; opacity: 1; transform: scale(1); }
  100% { visibility: hidden; display: none; height: 8px; opacity: 0; transform: scale(0.95); }
}

@keyframes headerSlideOutFrames { 
  0% { visibility: visible; display: flex; height: 48px; opacity: 1; transform: scale(1); }
  100% { visibility: hidden; display: none; height: 8px; opacity: 0; transform: scale(0.95); }
}

