[dir="ltr"] .ProgressSpinnerFlat > div:nth-child(4) { margin-left: 10px; }

[dir="rtl"] .ProgressSpinnerFlat > div:nth-child(4) { margin-right: 10px; }

.ProgressSpinnerFlat > div:nth-child(5) { animation-delay: 0.5s; }

[dir="ltr"] .ProgressSpinnerFlat > div:nth-child(5) { margin-left: 0px; }

[dir="rtl"] .ProgressSpinnerFlat > div:nth-child(5) { margin-right: 0px; }

@keyframes progress { 
  0% { left: -50px; }
  25% { left: -50px; }
  100% { left: 100%; }
}

@keyframes progressRtl { 
  0% { right: -50px; }
  25% { right: -50px; }
  100% { right: 100%; }
}
