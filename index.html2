.od-PermissionsPanel-entity { padding: 0.5rem 0px; font-size: 0.75rem; }

.od-PermissionsPanel-entity .od-Persona .od-Persona-details { display: inline-block; max-width: 200px; padding: 0px; }

.od-PermissionsPanel-addPeople { font-size: 1.0625rem; min-height: 3.125rem; padding-bottom: 0.625rem; }

.od-PermissionsPanel-addPeople-icon { display: inline-block; background-color: rgb(0, 120, 212); color: rgb(255, 255, 255); font-size: 1.25rem; border-radius: 50%; width: 3.125rem; height: 3.125rem; }

