@keyframes ms-motion-fadeIn { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes ms-motion-fadeOut { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes ms-motion-scaleDownIn { 
  0% { transform: scale3d(1.15, 1.15, 1); }
  100% { transform: scale3d(1, 1, 1); }
}

@keyframes ms-motion-scaleDownOut { 
  0% { transform: scale3d(1, 1, 1); }
  100% { transform: scale3d(0.9, 0.9, 1); }
}

@keyframes ms-motion-slideLeftOut { 
  0% { transform: translate3d(0px, 0px, 0px); }
  100% { transform: translate3d(-48px, 0px, 0px); }
}

@keyframes ms-motion-slideRightOut { 
  0% { transform: translate3d(0px, 0px, 0px); }
  100% { transform: translate3d(48px, 0px, 0px); }
}

@keyframes ms-motion-slideLeftIn { 
  0% { transform: translate3d(48px, 0px, 0px); }
  100% { transform: translate3d(0px, 0px, 0px); }
}

@keyframes ms-motion-slideRightIn { 
  0% { transform: translate3d(-48px, 0px, 0px); }
  100% { transform: translate3d(0px, 0px, 0px); }
}

@keyframes ms-motion-slideUpOut { 
  0% { transform: translate3d(0px, 0px, 0px); }
  100% { transform: translate3d(0px, -48px, 0px); }
}

@keyframes ms-motion-slideDownOut { 
  0% { transform: translate3d(0px, 0px, 0px); }
  100% { transform: translate3d(0px, 48px, 0px); }
}

@keyframes ms-motion-slideUpIn { 
  0% { transform: translate3d(0px, 48px, 0px); }
  100% { transform: translate3d(0px, 0px, 0px); }
}

@keyframes ms-motion-slideDownIn { 
  0% { transform: translate3d(0px, -48px, 0px); }
  100% { transform: translate3d(0px, 0px, 0px); }
}

.ms-motion-fadeIn { animation: 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeIn; }

.ms-motion-fadeOut { animation: 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeOut; }

.ms-motion-scaleDownIn { animation: 0.3s cubic-bezier(0.1, 0.9, 0.2, 1) 0s 1 normal both running ms-motion-scaleDownIn, 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeIn; }

.ms-motion-scaleDownOut { animation: 0.3s cubic-bezier(0.1, 0.9, 0.2, 1) 0s 1 normal both running ms-motion-scaleDownOut, 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeOut; }

[dir="ltr"] .ms-motion-slideLeftOut { animation: 0.1s cubic-bezier(0.9, 0.1, 1, 0.2) 0s 1 normal both running ms-motion-slideLeftOut, 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeOut; }

[dir="rtl"] .ms-motion-slideLeftOut { animation: 0.1s cubic-bezier(0.9, 0.1, 1, 0.2) 0s 1 normal both running ms-motion-slideRightOut, 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeOut; }

[dir="ltr"] .ms-motion-slideRightOut { animation: 0.1s cubic-bezier(0.9, 0.1, 1, 0.2) 0s 1 normal both running ms-motion-slideRightOut, 0.1s cubic-bezier(0, 0, 1, 1) 0s 1 normal both running ms-motion-fadeOut; }

