@charset "utf-8";

@keyframes commandBarBoxShadowAnimation { 
  0% { box-shadow: none; background-color: transparent; }
  100% { background-color: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0, 0.133) 0px 3.2px 7.2px 0px, rgba(0, 0, 0, 0.11) 0px 0.6px 1.8px 0px; }
}

@keyframes commandBarDividerAnimation { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

.od-TopBar-commandBar .ms-CommandBar button.is-pivot { position: relative; border-bottom: 2px solid transparent; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot .ms-Button-label::after { transition: 0.1s ease-in-out; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot:hover { background-color: rgb(240, 240, 240); border-bottom: 2px solid transparent; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot:active { background-color: rgb(235, 235, 235); border-bottom: 2px solid rgb(0, 120, 212); }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled { border-bottom: 2px solid transparent; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view:hover, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled:hover { background-color: rgb(240, 240, 240); border-bottom: 2px solid transparent; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view:hover .ms-Button-label::after, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled:hover .ms-Button-label::after { width: 100%; left: 0px; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view .ms-Button-label, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled .ms-Button-label { font-weight: 600; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view .ms-Button-label::after, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled .ms-Button-label::after { content: ""; display: block; position: absolute; left: 8px; border-bottom: 2px solid rgb(0, 120, 212); bottom: -2px; width: calc(100% - 16px); }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view .ms-Button-flexContainer, .isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled .ms-Button-flexContainer { height: 100%; }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view:hover .ms-Button-flexContainer, .isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled:hover .ms-Button-flexContainer { background-color: inherit; }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view:active .ms-Button-flexContainer, .isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled:active .ms-Button-flexContainer { background-color: inherit; }

.od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-current-view, .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-toggled { font-weight: 600; }

[dir="ltr"] .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-last-pivot { margin-right: 24px; }

[dir="rtl"] .od-TopBar-commandBar .ms-CommandBar button.is-pivot.is-last-pivot { margin-left: 24px; }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-pivot:active { border-bottom-left-radius: 0px; border-bottom-right-radius: 0px; }

.od-TopBar-commandBar .ms-CommandBar button.is-toggled { background-color: rgb(235, 235, 235); color: rgb(0, 0, 0); }

.od-TopBar-commandBar .ms-CommandBar button.is-toggled:hover { background-color: rgb(224, 224, 224); }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-toggled { background-color: transparent; color: rgb(0, 120, 212); }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-toggled .ms-Button-flexContainer { background-color: rgb(235, 235, 235); }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-toggled:hover { background-color: transparent; }

.isFluentVNext .od-TopBar-commandBar .ms-CommandBar button.is-toggled:hover .ms-Button-flexContainer { background-color: rgb(224, 224, 224); }

.od-TopBar-commandBar.od--hasSelection .ms-CommandBar { background-color: rgb(240, 240, 240); transition: background-color 467ms cubic-bezier(0.1, 0.9, 0.2, 1); }

.od-TopBar-commandBar.od--hasSelection .ms-Button--commandBar { color: rgb(20, 20, 20); background-color: rgb(240, 240, 240); transition: background-color 467ms cubic-bezier(0.1, 0.9, 0.2, 1); }

.od-TopBar-commandBar.od--hasSelection .ms-Button--commandBar:hover { background-color: rgb(235, 235, 235); }

