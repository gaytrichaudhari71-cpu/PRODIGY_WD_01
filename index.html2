.OD3Scrollbar ::-webkit-scrollbar-thumb { background-clip: content-box; border-radius: var(--borderRadiusXLarge); border: 4px solid transparent; background-color: var(--colorNeutralForeground4); }

.OD3Scrollbar ::-webkit-scrollbar-thumb:hover { background-color: var(--colorNeutralForeground3); }

.OD3Scrollbar ::-webkit-scrollbar-button { display: none; }

.OD3Scrollbar ::-webkit-scrollbar-corner { background: 0px 0px; }

@media (forced-colors: active) {
  .OD3Scrollbar ::-webkit-scrollbar { scrollbar-color: canvastext transparent; }
  .OD3Scrollbar ::-webkit-scrollbar-thumb { background-color: canvastext; border: 4px solid window; }
}
